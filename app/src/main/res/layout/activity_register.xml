<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FC"
    android:fillViewport="true"
    tools:context=".ui.auth.RegisterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Đăng ký tài khoản"
            android:textColor="#071B33"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Tạo tài khoản để bắt đầu"
            android:textColor="#72727D"
            android:textSize="16sp" />

        <!-- Full name label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:text="HỌ VÀ TÊN"
            android:textColor="#8A8D96"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Full name input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="User icon"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#6F737D" />

            <EditText
                android:id="@+id/etFullName"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Nguyễn Văn A"
                android:inputType="textPersonName"
                android:padding="0dp"
                android:textColor="#1F2937"
                android:textColorHint="#4A4A55"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Email label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="EMAIL"
            android:textColor="#8A8D96"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Email input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Email icon"
                android:src="@android:drawable/ic_dialog_email"
                app:tint="#6F737D" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="example@domain.com"
                android:inputType="textEmailAddress"
                android:padding="0dp"
                android:textColor="#1F2937"
                android:textColorHint="#4A4A55"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Password label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="MẬT KHẨU"
            android:textColor="#8A8D96"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Password input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Password icon"
                android:src="@android:drawable/ic_lock_lock"
                app:tint="#6F737D" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:padding="0dp"
                android:textColor="#1F2937"
                android:textColorHint="#4A4A55"
                android:textSize="18sp" />

            <ImageView
                android:id="@+id/imgTogglePassword"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:contentDescription="Show password"
                android:src="@android:drawable/ic_menu_view"
                app:tint="#6F737D" />
        </LinearLayout>

        <!-- Confirm password label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="NHẬP LẠI MẬT KHẨU"
            android:textColor="#8A8D96"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Confirm password input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Confirm password icon"
                android:src="@android:drawable/ic_lock_lock"
                app:tint="#6F737D" />

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:padding="0dp"
                android:textColor="#1F2937"
                android:textColorHint="#4A4A55"
                android:textSize="18sp" />

            <ImageView
                android:id="@+id/imgToggleConfirmPassword"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:contentDescription="Show confirm password"
                android:src="@android:drawable/ic_menu_view"
                app:tint="#6F737D" />
        </LinearLayout>

        <!-- Register button -->
        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/bg_button_primary"
            android:elevation="8dp"
            android:text="Đăng ký"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="44dp"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#D2D5DC" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Hoặc đăng ký bằng"
                android:textColor="#777985"
                android:textSize="16sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#D2D5DC" />
        </LinearLayout>

        <!-- Google register -->
        <LinearLayout
            android:id="@+id/btnGoogleRegister"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_social_button"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:contentDescription="Google"
                android:src="@drawable/ic_google" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="Tiếp tục với Google"
                android:textColor="#3F3F46"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- Go login -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="54dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bạn đã có tài khoản? "
                android:textColor="#6D6D78"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvGoLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đăng nhập ngay"
                android:textColor="#00709E"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>