<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FC"
    android:fillViewport="true"
    tools:context=".ui.profile.ProfileFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="120dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="‹"
                android:textColor="#071B33"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="Tài khoản"
                android:textColor="#06285D"
                android:textSize="30sp"
                android:textStyle="bold" />

            <View
                android:layout_width="48dp"
                android:layout_height="48dp" />
        </LinearLayout>

        <!-- User card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginTop="26dp"
            android:background="@drawable/bg_white_card"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="112dp"
                android:layout_height="112dp">

                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="104dp"
                    android:layout_height="104dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_avatar_circle"
                    android:contentDescription="Avatar"
                    android:padding="4dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/logo" />

                <View
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_online_dot" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvFullName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:text="Nguyễn Văn An"
                android:textColor="#071B33"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="an.nguyen@email.com"
                android:textColor="#6D6D78"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Setting title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:letterSpacing="0.16"
            android:text="CÀI ĐẶT CHUNG"
            android:textColor="#5F636D"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Setting card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_white_card"
            android:orientation="vertical">

            <!-- Reminder row -->
            <LinearLayout
                android:id="@+id/layoutReminder"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_setting_icon"
                    android:gravity="center"
                    android:text="♧"
                    android:textColor="#0079B8"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:text="Nhắc nhở học tập"
                    android:textColor="#071B33"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <Switch
                    android:id="@+id/switchReminder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E1EAF8" />

            <!-- Change password row -->
            <LinearLayout
                android:id="@+id/layoutChangePassword"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_setting_icon"
                    android:gravity="center"
                    android:text="▣"
                    android:textColor="#0079B8"
                    android:textSize="26sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:text="Đổi mật khẩu"
                    android:textColor="#071B33"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="#6D6D78"
                    android:textSize="36sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Support title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:letterSpacing="0.16"
            android:text="HỖ TRỢ &amp; GIẢI ĐÁP"
            android:textColor="#5F636D"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- FAQ card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_white_card"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/layoutFaqScore"
                android:layout_width="match_parent"
                android:layout_height="112dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_setting_icon"
                    android:gravity="center"
                    android:text="?"
                    android:textColor="#0079B8"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="AI chấm điểm dựa trên tiêu chí nào?"
                        android:textColor="#071B33"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvFaqScoreDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="AI phân tích dựa trên ngữ pháp, từ vựng, mạch lạc và mức độ phù hợp chủ đề."
                        android:textColor="#6D6D78"
                        android:textSize="14sp"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⌄"
                    android:textColor="#6D6D78"
                    android:textSize="28sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E1EAF8" />

            <LinearLayout
                android:id="@+id/layoutFaqSave"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_setting_icon"
                    android:gravity="center"
                    android:text="▱"
                    android:textColor="#0079B8"
                    android:textSize="26sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:text="Làm sao để lưu bài viết?"
                    android:textColor="#071B33"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⌄"
                    android:textColor="#6D6D78"
                    android:textSize="28sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Logout -->
        <TextView
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginTop="60dp"
            android:background="@drawable/bg_logout_button"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:text="↪  Đăng xuất"
            android:textColor="#B91C1C"
            android:textSize="18sp" />

    </LinearLayout>
</ScrollView>